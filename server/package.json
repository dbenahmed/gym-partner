{
  "name": "gym-partner",
  "version": "1.0.0",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "test": "nodemon playground.js",
    "start": "node app.js",
    "dev": "nodemon app.js  --serveonet",
    "local": "nodemon app.js --local",
    "prod": "nodemon app.js",
    "drizzle:dev:generate": "drizzle-kit generate --config=drizzle-dev.config.ts",
    "drizzle:dev:migrate": "drizzle-kit migrate --config=drizzle-dev.config.ts",
    "drizzle:dev:seed": "node db/seeds/index.js",
    "drizzle:dev:seed:mock": "node db/seeds/seedMockData.js",
    "drizzle:dev:clearseed": "node ./db/seeds/clearSeeds.js",
    "drizzle:main:generate": "drizzle-kit generate --config=drizzle-main.config.ts",
    "drizzle:main:migrate": "drizzle-kit migrate --config=drizzle-main.config.ts",
    "drizzle:main:seed": "node db/seeds/index.js",
    "drizzle:main:seed:mock": "node db/seeds/seedMockData.js",
    "drizzle:main:clearseed": "node ./db/seeds/clearSeeds.js",
    "drizzle:main:studio": "npx drizzle-kit studio --port 3000 --verbose --config=drizzle-main.config.ts",
    "drizzle:dev:studio": "npx drizzle-kit studio --port 3020 --verbose --config=drizzle-dev.config.ts",
    "drizzle:dev:push": "npx drizzle-kit push --config=drizzle-dev.config.ts --strict --verbose"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0",
    "drizzle-seed": "^0.3.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.3",
    "serveonet": "^0.0.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.4",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2"
  }
}
